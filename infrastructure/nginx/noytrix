server {
    server_name noytrix.com;

    # если нужно раздавать статику (не обязательно):
    # location /static/ {
    #     alias /var/www/noytrix/static/;
    # }
    # Статика-страницы
location = /privacy    { default_type text/html; alias /var/www/noytrix/legal/privacy.html;    expires -1; }
location = /terms      { default_type text/html; alias /var/www/noytrix/legal/terms.html;      expires -1; }
location = /disclaimer { default_type text/html; alias /var/www/noytrix/legal/disclaimer.html; expires -1; }

    location / {
        proxy_pass         http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 120;
    }

    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/noytrix.com/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/noytrix.com/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot


}

server {
    if ($host = www.noytrix.com) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    if ($host = noytrix.com) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    listen 80;
    server_name noytrix.com www.noytrix.com;
    return 404; # managed by Certbot




}
